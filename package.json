{
  "name": "neon-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:drums": "npm run dev -w @neon/drums",
    "dev:synth": "npm run dev -w @neon/synth",
    "dev:noise": "npm run dev -w @neon/noise",
    "dev:studio": "npm run dev -w @neon/studio",
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build -w @neon/fx -w @neon/cloud -w @neon/ui -w @neon/ai -w @neon/instruments -w @neon/engine",
    "preview:drums": "npm run preview -w @neon/drums",
    "preview:synth": "npm run preview -w @neon/synth",
    "preview:noise": "npm run preview -w @neon/noise",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run typecheck",
    "clean": "rm -rf packages/*/dist apps/*/dist node_modules/.vite coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.11.0",
    "d3": "^7.8.5",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "jsdom": "^24.0.0",
    "terser": "^5.46.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.53.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0"
  }
}
