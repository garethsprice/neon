{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@neon/ui": ["./packages/neon-ui/src/index.ts"],
      "@neon/ui/*": ["./packages/neon-ui/src/*"],
      "@neon/fx": ["./packages/neon-fx/src/index.ts"],
      "@neon/fx/*": ["./packages/neon-fx/src/*"],
      "@neon/cloud": ["./packages/neon-cloud/src/index.ts"],
      "@neon/cloud/*": ["./packages/neon-cloud/src/*"],
      "@neon/ai": ["./packages/neon-ai/src/index.ts"],
      "@neon/ai/*": ["./packages/neon-ai/src/*"],
      "@neon/instruments": ["./packages/neon-instruments/src/index.ts"],
      "@neon/instruments/*": ["./packages/neon-instruments/src/*"],
      "@neon/engine": ["./packages/neon-engine/src/index.ts"],
      "@neon/engine/*": ["./packages/neon-engine/src/*"]
    },
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "exclude": ["node_modules", "**/dist", "**/coverage"]
}
